# HTTP API reference (routes, payloads): docs/API.md

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
INTERNAL_ADMIN_API_KEY=replace-with-a-long-random-admin-token
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PUBLIC_REQUESTS=10
CTA_TRACK_RATE_LIMIT_MAX=60
DIAGNOSTIC_DUPLICATE_WINDOW_HOURS=24

# -----------------------------------------------------------------------------
# Auth (Supabase Auth + API routes under /api/auth/*)
# -----------------------------------------------------------------------------
# Absolute site URL used to build email/OAuth redirect URLs (e.g. password reset).
# Required for signup, forgot-password, and OAuth callback flows in production.
# NEXT_PUBLIC_APP_URL is set above for local dev.

# Paths are relative to the site origin (must start with /).
NEXT_PUBLIC_AUTH_CALLBACK_PATH=/api/auth/callback
NEXT_PUBLIC_AUTH_POST_LOGIN_PATH=/
NEXT_PUBLIC_AUTH_ERROR_PATH=/login

# In Supabase Dashboard: Authentication > URL configuration
# - Site URL: match NEXT_PUBLIC_APP_URL in production (e.g. https://ribuzz.co)
# - Redirect URLs: allow your callback, e.g. http://localhost:3000/api/auth/callback
#   and production https://your-domain/api/auth/callback

# Optional: tighten or loosen in-memory rate limits for public auth endpoints (per IP).
AUTH_RATE_LIMIT_MAX_SIGNUP=10
AUTH_RATE_LIMIT_MAX_LOGIN=20
AUTH_RATE_LIMIT_MAX_FORGOT_PASSWORD=10

# -----------------------------------------------------------------------------
# Local Supabase in Docker (Supabase CLI: supabase start)
# -----------------------------------------------------------------------------
# See README "Supabase local (Docker, CLI)". Committed template with demo JWTs:
#   .env.supabase.docker
# Smoke test (requires stack running): npm run test:supabase:docker
